<div class="centered-page">
  <%= simple_form_for @item do |f| %>
    <div>
      <%= f.input :name %>
      <div class="d-flex gap-3">
        <%= f.button :submit, "Add Item", class: "btn" %>
        <%= link_to "Back to Items", root_path, class: "btn" %>
      </div>
    </div>
  <% end %>
</div>