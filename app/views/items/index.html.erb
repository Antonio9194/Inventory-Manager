<div class="page-header">
  <h1 class="brand-name">Morikoya</h1>
  <p class="brand-sub">Inventory Manager</p>
</div>
<div class="top-bar">
  <%= link_to "Add New Item", new_item_path, class: "btn-primary" %>
</div>
<div class="inventory-grid">
  <% @items.each do |item| %>
    <div class="inventory-card">
      <div class="card-header">
        <%= link_to item.name, item_path(item), class: "item-name" %>
      </div>
      <div class="card-body">
        <p class="stock">
          Stock: 
          <span class="<%= 'low' if item.low_stock? %>">
            <%= item.current_stock %>
          </span>
        </p>
        <% if item.low_stock? %>
          <div class="alert">
            ⚠ Restock Immediately
          </div>
        <% end %>
      </div>
      <div class="card-footer">
        <%= link_to "Delete", confirm_delete_item_path(item),
          class: "btn-danger",
          data: { turbo_frame: "modal" } %>
      </div>
    </div>
  <% end %>
</div>
<turbo-frame id="modal"></turbo-frame>